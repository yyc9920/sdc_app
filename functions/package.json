    "firebase-functions": "^4.7.0",
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/papaparse": "^5.3.14",
    "firebase-functions-test": "^3.3.0",
    "typescript": "^5.4.5"
  },
